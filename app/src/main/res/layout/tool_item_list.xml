<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:foreground="@drawable/ripple_rounded_blue">

    <View
        android:id="@+id/tool_cell_background"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@drawable/mapcell_list"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/tool_icon_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/map_image_rounded"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_tools_navbutton"
        app:layout_constraintBottom_toBottomOf="@id/tool_cell_background"
        app:layout_constraintStart_toStartOf="@id/tool_cell_background"
        app:layout_constraintTop_toTopOf="@id/tool_cell_background" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/tool_cell_background"
        app:layout_constraintEnd_toEndOf="@id/tool_cell_background"
        app:layout_constraintStart_toEndOf="@id/tool_icon_image"
        app:layout_constraintTop_toTopOf="@id/tool_cell_background">

        <TextView
            android:id="@+id/tool_name_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nz_font"
            android:text="Tool Name"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tool_description_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Short tool description goes here..."
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:alpha="0.7" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
