<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_rounded_blue">

    <View
        android:id="@+id/map_cell_background"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@drawable/mapcell_list"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/map_cover_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:padding="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/app_icon"
        app:layout_constraintBottom_toBottomOf="@id/map_cell_background"
        app:layout_constraintStart_toStartOf="@id/map_cell_background"
        app:layout_constraintTop_toTopOf="@id/map_cell_background" />

    <TextView
        android:id="@+id/map_name_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Map Name Here"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/nazi_zombies_font"
        app:layout_constraintBottom_toBottomOf="@id/map_cell_background"
        app:layout_constraintEnd_toEndOf="@id/map_cell_background"
        app:layout_constraintStart_toEndOf="@id/map_cover_image"
        app:layout_constraintTop_toTopOf="@id/map_cell_background" />

</androidx.constraintlayout.widget.ConstraintLayout>