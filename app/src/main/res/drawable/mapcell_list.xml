<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base full horizontal rectangle cell shape -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_dark" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="@color/divider_dark" />
        </shape>
    </item>

    <!-- Side label/image rectangle (approx 1/3rd width) on the left -->
    <item android:width="120dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="@color/divider_dark" />
            <corners
                android:topLeftRadius="12dp"
                android:bottomLeftRadius="12dp"
                android:topRightRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>